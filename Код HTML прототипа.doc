<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>cpo-mvp-clickable-demo-spacing-fixed code</title>
<style>
body { font-family: Consolas, 'Courier New', monospace; margin: 24px; white-space: pre-wrap; word-break: break-word; font-size: 10pt; }
h1 { font-family: Arial, sans-serif; font-size: 16pt; white-space: normal; }
p.meta { font-family: Arial, sans-serif; white-space: normal; color: #555; margin-bottom: 18px; }
pre { white-space: pre-wrap; word-break: break-word; border: 1px solid #ccc; padding: 12px; background: #f7f7f7; }
</style>
</head>
<body>
<h1>Код последней версии HTML-файла</h1>
<p class="meta">Файл содержит полный код версии cpo-mvp-clickable-demo-spacing-fixed.html.</p>
<pre>&lt;!DOCTYPE html&gt;
&lt;html lang=&quot;ru&quot;&gt;
&lt;head&gt;
  &lt;meta charset=&quot;UTF-8&quot; /&gt;
  &lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot; /&gt;
  &lt;title&gt;CPO Simulator Demo&lt;/title&gt;
  &lt;link rel=&quot;preconnect&quot; href=&quot;https://fonts.googleapis.com&quot;&gt;
  &lt;link rel=&quot;preconnect&quot; href=&quot;https://fonts.gstatic.com&quot; crossorigin&gt;
  &lt;link href=&quot;https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap&quot; rel=&quot;stylesheet&quot;&gt;
  &lt;style&gt;
    :root {
      --bg:#070910;
      --bg-2:#0d1220;
      --panel:rgba(11,15,26,.84);
      --panel-border:rgba(255,255,255,.08);
      --text:#eef2ff;
      --text-muted:#adb5cb;
      --surface:#ffffff;
      --surface-subtle:#f8f9fd;
      --surface-soft:#eef2f7;
      --surface-line:#dde3ef;
      --text-dark:#111827;
      --text-soft:#5f687c;
      --primary:#8b5cf6;
      --primary-2:#6d7dff;
      --primary-soft:#f1edff;
      --success:#16a34a;
      --success-soft:#dcfce7;
      --warning:#d97706;
      --warning-soft:#fef3c7;
      --radius-shell:36px;
      --radius-screen:30px;
      --radius-card:24px;
      --radius-pill:999px;
      --shadow-shell:0 28px 80px rgba(0,0,0,.42);
      --shadow-card:0 16px 36px rgba(15,23,42,.08);
      --space-2:8px;
      --space-3:12px;
      --space-4:16px;
      --space-5:20px;
      --space-6:24px;
      --space-8:32px;
    }

    * { box-sizing:border-box; margin:0; padding:0; }
    html, body { height:100%; }
    body {
      font-family:Inter, system-ui, sans-serif;
      background:
        radial-gradient(circle at 10% 0%, rgba(109,125,255,.20), transparent 24%),
        radial-gradient(circle at 90% 10%, rgba(139,92,246,.18), transparent 22%),
        linear-gradient(180deg, #12182b 0%, #090c15 52%, #06080f 100%);
      color:var(--text);
      font-size:16px;
      line-height:1.55;
      overflow-x:hidden;
    }

    button, input, textarea { font:inherit; }
    button { cursor:pointer; border:none; }
    [hidden] { display:none !important; }

    .app {
      max-width:1440px;
      margin:0 auto;
      padding:24px;
    }

    .layout {
      display:grid;
      grid-template-columns:280px minmax(0,1fr);
      gap:18px;
      align-items:start;
    }

    .sidebar {
      position:sticky;
      top:24px;
      background:var(--panel);
      border:1px solid var(--panel-border);
      border-radius:30px;
      padding:16px;
      box-shadow:var(--shadow-shell);
      backdrop-filter:blur(18px);
    }

    .side-head {
      margin-bottom:12px;
      font-size:12px;
      letter-spacing:.08em;
      text-transform:uppercase;
      color:#8f98b0;
    }

    .tabs {
      display:grid;
      gap:10px;
    }

    .tab {
      padding:17px;
      border-radius:18px;
      text-align:left;
      background:transparent;
      color:var(--text);
      border:1px solid transparent;
      transition:.2s ease;
    }

    .tab:hover {
      background:rgba(255,255,255,.04);
    }

    .tab.active {
      background:linear-gradient(135deg, rgba(139,92,246,.18), rgba(109,125,255,.12));
      border-color:rgba(139,92,246,.25);
    }

    .tab span {
      display:block;
      margin-top:5px;
      font-size:13px;
      color:#aab2c8;
    }

    .device {
      background:var(--panel);
      border:1px solid var(--panel-border);
      border-radius:var(--radius-shell);
      padding:14px;
      box-shadow:var(--shadow-shell);
      overflow:hidden;
    }

    .device-inner {
      min-height:860px;
      background:linear-gradient(180deg, #f7f9fd, #eef2f8);
      border-radius:var(--radius-screen);
      overflow:hidden;
      color:var(--text-dark);
    }

    .ui-top {
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:12px;
      padding:18px 22px;
      background:rgba(255,255,255,.75);
      border-bottom:1px solid var(--surface-line);
    }

    .ui-title {
      font-size:20px;
      font-weight:800;
      letter-spacing:-.02em;
      color:var(--text-dark);
    }

    .ui-sub {
      font-size:13px;
      color:#667085;
    }

    .ui-body {
      display:grid;
      gap:20px;
      padding:24px;
    }

    .screen { display:none; }
    .screen.active { display:grid; gap:20px; }

    .section-header {
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:16px;
      padding-bottom:4px;
    }

    .stepper {
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .step-btn,
    .badge,
    .status,
    .chip {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-height:42px;
      padding:10px 14px;
      border-radius:var(--radius-pill);
      font-size:13px;
      font-weight:700;
    }

    .step-btn {
      background:var(--surface-soft);
      color:var(--text-soft);
      border:1px solid var(--surface-line);
    }

    .step-btn.active {
      background:linear-gradient(135deg, var(--primary), var(--primary-2));
      color:#fff;
      border-color:transparent;
    }

    .badge {
      min-height:auto;
      padding:8px 12px;
      background:#ede9fe;
      color:var(--primary);
    }

    .status.wait {
      min-height:auto;
      padding:8px 12px;
      background:var(--warning-soft);
      color:var(--warning);
    }

    .status.ok {
      min-height:auto;
      padding:8px 12px;
      background:var(--success-soft);
      color:var(--success);
    }

    .chip {
      min-height:auto;
      padding:8px 12px;
      background:var(--surface-soft);
      color:#596579;
    }

    .chip.green {
      background:var(--success-soft);
      color:#15803d;
    }

    .chip.purple {
      background:var(--primary-soft);
      color:var(--primary);
    }

    .demo-stage {
      display:grid;
      gap:20px;
      padding:22px;
      background:var(--surface);
      border:1px solid var(--surface-line);
      border-radius:var(--radius-screen);
      box-shadow:var(--shadow-card);
    }

    .row,
    .row-3,
    .split,
    .skill-grid,
    .stack {
      display:grid;
      gap:18px;
    }

    .row { grid-template-columns:repeat(2, minmax(0,1fr)); }
    .row-3 { grid-template-columns:repeat(3, minmax(0,1fr)); }
    .split { grid-template-columns:1.12fr .88fr; }
    .skill-grid { grid-template-columns:repeat(3, minmax(0,1fr)); }

    .panel,
    .card,
    .upload,
    .skill,
    .result,
    .block {
      padding:20px;
      background:var(--surface);
      border:1px solid var(--surface-line);
      border-radius:var(--radius-card);
      box-shadow:var(--shadow-card);
      color:var(--text-dark);
    }

    .panel h3,
    .card h3,
    .upload h3,
    .skill h3,
    .result h3,
    .block h3 {
      letter-spacing:-.02em;
    }

    .panel p,
    .card p,
    .upload p,
    .skill p,
    .result p,
    .block p {
      color:var(--text-soft);
      margin-top:8px;
    }

    .subtle {
      background:var(--surface-subtle);
    }

    .result-highlight {
      background:linear-gradient(135deg, #ffffff, #f5f2ff);
    }

    .button {
      display:inline-flex;
      align-items:center;
      justify-content:center;
      min-width:132px;
      height:48px;
      padding:0 18px;
      border-radius:15px;
      font-weight:700;
      transition:.2s ease;
    }

    .button:hover:not(:disabled) {
      transform:translateY(-1px);
    }

    .button.primary {
      background:linear-gradient(135deg, var(--primary), var(--primary-2));
      color:#fff;
    }

    .button.secondary {
      background:#fff;
      border:1px solid var(--surface-line);
      color:var(--text-dark);
    }

    .button.ghost {
      background:#f4f7fc;
      color:#556071;
    }

    .button:disabled {
      opacity:.45;
      cursor:not-allowed;
    }

    .section-title,
    .footer-actions,
    .meta,
    .chips {
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      flex-wrap:wrap;
    }

    .upload {
      display:grid;
      gap:12px;
      border-style:dashed;
      background:linear-gradient(180deg, #fff, #fbfcff);
    }

    .upload.good {
      background:#f6fff8;
      border-color:#86efac;
    }

    .hidden-input {
      display:none;
    }

    .progress {
      height:12px;
      background:#e9edf7;
      border-radius:var(--radius-pill);
      overflow:hidden;
    }

    .progress &gt; span {
      display:block;
      height:100%;
      border-radius:var(--radius-pill);
      background:linear-gradient(90deg, var(--primary), var(--primary-2));
    }

    .field {
      display:grid;
      gap:8px;
    }

    .field label {
      font-size:14px;
      font-weight:700;
      color:#344054;
    }

    .textarea {
      width:100%;
      min-height:180px;
      padding:16px;
      border:1px solid #dbe2ee;
      border-radius:16px;
      background:#fff;
      color:#111827;
      resize:none;
    }

    .meta {
      font-size:13px;
      color:#6b7280;
    }

    .skill {
      display:grid;
      gap:12px;
      background:linear-gradient(180deg, #fff, #fbfbff);
    }

    .option-list {
      display:grid;
      gap:10px;
      margin-top:12px;
    }

    .option {
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      padding:15px 16px;
      background:#fff;
      border:1px solid #d9e0ec;
      border-radius:16px;
    }

    .option.active {
      background:#f5f1ff;
      border-color:rgba(139,92,246,.38);
    }

    .score {
      font-size:36px;
      font-weight:800;
      color:var(--text-dark);
      margin-top:10px;
      line-height:1;
    }

    .section-gap-top { margin-top:16px; }

    .section-gap-sm { margin-top:10px; }

    .stack-tight { display:grid; gap:12px; }

.upload-zone {
      margin-top:12px;
      padding-top:16px;
      border-top:1px solid #edf1f7;
    }

    @media (max-width:1120px) {
      .layout,
      .row,
      .row-3,
      .split,
      .skill-grid {
        grid-template-columns:1fr;
      }

      .sidebar {
        position:static;
      }

      .device-inner {
        min-height:auto;
      }

      .section-header {
        align-items:flex-start;
      }

      .button {
        width:100%;
      }
    }
  &lt;/style&gt;
&lt;/head&gt;
&lt;body&gt;
  &lt;div class=&quot;app&quot;&gt;
    &lt;section class=&quot;layout&quot;&gt;
      &lt;aside class=&quot;sidebar&quot;&gt;
        &lt;div class=&quot;side-head&quot;&gt;Навигация по сценарию&lt;/div&gt;
        &lt;div class=&quot;tabs&quot;&gt;
          &lt;button class=&quot;tab active&quot; data-screen=&quot;diagnostic&quot;&gt;
            &lt;strong&gt;Диагностика продуктовых навыков&lt;/strong&gt;
            &lt;span&gt;Вступление, задание, анализ, результаты&lt;/span&gt;
          &lt;/button&gt;
          &lt;button class=&quot;tab&quot; data-screen=&quot;simulator&quot;&gt;
            &lt;strong&gt;Симулятор продуктовых навыков&lt;/strong&gt;
            &lt;span&gt;Навыки, прохождение, итог&lt;/span&gt;
          &lt;/button&gt;
        &lt;/div&gt;
      &lt;/aside&gt;

      &lt;main class=&quot;device&quot;&gt;
        &lt;div class=&quot;device-inner&quot;&gt;
          &lt;div class=&quot;ui-top&quot;&gt;
            &lt;div&gt;
              &lt;div class=&quot;ui-title&quot; id=&quot;screenTitle&quot;&gt;Диагностика продуктовых навыков&lt;/div&gt;
              &lt;div class=&quot;ui-sub&quot; id=&quot;screenSubtitle&quot;&gt;Загрузите материалы и пройдите оценку навыков&lt;/div&gt;
            &lt;/div&gt;
            &lt;div class=&quot;badge&quot; id=&quot;screenBadge&quot;&gt;Раздел 1&lt;/div&gt;
          &lt;/div&gt;

          &lt;div class=&quot;ui-body&quot;&gt;
            &lt;section class=&quot;screen active&quot; id=&quot;screen-diagnostic&quot;&gt;
              &lt;div class=&quot;section-header&quot;&gt;
                &lt;h3&gt;Диагностика продуктовых навыков&lt;/h3&gt;
                &lt;div class=&quot;stepper&quot;&gt;
                  &lt;button class=&quot;step-btn active&quot; data-diag-step=&quot;intro&quot;&gt;Вступление&lt;/button&gt;
                  &lt;button class=&quot;step-btn&quot; data-diag-step=&quot;task&quot;&gt;Задание&lt;/button&gt;
                  &lt;button class=&quot;step-btn&quot; data-diag-step=&quot;processing&quot;&gt;Анализ&lt;/button&gt;
                  &lt;button class=&quot;step-btn&quot; data-diag-step=&quot;results&quot;&gt;Результаты&lt;/button&gt;
                &lt;/div&gt;
              &lt;/div&gt;

              &lt;div class=&quot;demo-stage&quot;&gt;
                &lt;div class=&quot;split&quot; data-diag-view=&quot;intro&quot;&gt;
                  &lt;div class=&quot;panel&quot;&gt;
                    &lt;div class=&quot;section-title&quot;&gt;
                      &lt;h3&gt;Вступление в диагностику&lt;/h3&gt;
                      &lt;span class=&quot;chip purple&quot;&gt;11 заданий&lt;/span&gt;
                    &lt;/div&gt;
                    &lt;p&gt;Кейс: продукт сталкивается с замедлением активации и снижением конверсии в ключевом пользовательском сценарии. Ваша задача — проанализировать проблему и предложить продуктовые решения.&lt;/p&gt;
                    &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                      &lt;button class=&quot;button primary&quot; data-diag-next=&quot;task&quot;&gt;Начать диагностику&lt;/button&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;card result-highlight&quot;&gt;
                    &lt;h3&gt;Формат прохождения&lt;/h3&gt;
                    &lt;p&gt;11 последовательных заданий, сохранение ответов и переход к результатам после завершения анализа.&lt;/p&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div class=&quot;panel&quot; data-diag-view=&quot;task&quot; hidden&gt;
                  &lt;div class=&quot;section-title&quot;&gt;
                    &lt;h3&gt;Задание 5 из 11&lt;/h3&gt;
                    &lt;span class=&quot;chip&quot;&gt;Навык: Гипотезы&lt;/span&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;progress section-gap-top&quot;&gt;&lt;span class=&quot;progress-45&quot;&gt;&lt;/span&gt;&lt;/div&gt;
                  &lt;div class=&quot;block subtle section-gap-top&quot;&gt;
                    &lt;h3&gt;Какую гипотезу вы бы проверили первой и почему?&lt;/h3&gt;
                    &lt;p&gt;Опишите логику выбора, влияние на ключевую метрику и способ оценки результата после эксперимента.&lt;/p&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;field section-gap-top&quot;&gt;
                    &lt;label&gt;Ответ&lt;/label&gt;
                    &lt;textarea class=&quot;textarea&quot;&gt;Я бы начал с гипотезы, которая влияет на активацию в первом ценном действии пользователя. Затем определил бы ключевую метрику, guardrail-метрики и критерии успеха эксперимента...&lt;/textarea&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;meta&quot;&gt;
                    &lt;span&gt;Минимум 50 символов&lt;/span&gt;
                    &lt;span&gt;168 символов&lt;/span&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                    &lt;button class=&quot;button ghost&quot; data-diag-next=&quot;intro&quot;&gt;Назад&lt;/button&gt;
                    &lt;button class=&quot;button primary&quot; data-diag-next=&quot;processing&quot;&gt;Завершить диагностику&lt;/button&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div class=&quot;panel result-highlight&quot; data-diag-view=&quot;processing&quot; hidden&gt;
                  &lt;div class=&quot;section-title&quot;&gt;
                    &lt;h3&gt;Анализ ответов&lt;/h3&gt;
                    &lt;span class=&quot;chip purple&quot;&gt;AI-ready&lt;/span&gt;
                  &lt;/div&gt;
                  &lt;p&gt;Оцениваем ответы, формируем комментарии и рекомендации по навыкам.&lt;/p&gt;
                  &lt;div class=&quot;progress section-gap-top&quot;&gt;&lt;span id=&quot;processingBar&quot; class=&quot;progress-15&quot;&gt;&lt;/span&gt;&lt;/div&gt;
                  &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                    &lt;button class=&quot;button ghost&quot; data-diag-next=&quot;task&quot;&gt;Назад&lt;/button&gt;
                    &lt;button class=&quot;button primary&quot; id=&quot;finishProcessing&quot;&gt;Показать результаты&lt;/button&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div data-diag-view=&quot;results&quot; hidden&gt;
                  &lt;div class=&quot;row-3&quot;&gt;
                    &lt;div class=&quot;result result-highlight stack-tight&quot;&gt;
                      &lt;h3&gt;Анализ рынка&lt;/h3&gt;
                      &lt;div class=&quot;score&quot;&gt;4/6&lt;/div&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip green&quot;&gt;Рекомендован&lt;/span&gt;&lt;/div&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;result stack-tight&quot;&gt;
                      &lt;h3&gt;Метрики продукта&lt;/h3&gt;
                      &lt;div class=&quot;score&quot;&gt;5/6&lt;/div&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip&quot;&gt;Сильная зона&lt;/span&gt;&lt;/div&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;result result-highlight stack-tight&quot;&gt;
                      &lt;h3&gt;Гипотезы&lt;/h3&gt;
                      &lt;div class=&quot;score&quot;&gt;3/6&lt;/div&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip green&quot;&gt;Рекомендован&lt;/span&gt;&lt;/div&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;row section-gap-top&quot;&gt;
                    &lt;div class=&quot;panel&quot;&gt;
                      &lt;h3&gt;Комментарии&lt;/h3&gt;
                      &lt;p&gt;Ответы структурированы, но в ряде кейсов не хватает приоритизации и связки между решением, метрикой и ожидаемым эффектом.&lt;/p&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;panel&quot;&gt;
                      &lt;h3&gt;Рекомендации&lt;/h3&gt;
                      &lt;div class=&quot;chips section-gap-top&quot;&gt;
                        &lt;span class=&quot;chip green&quot;&gt;Анализ рынка&lt;/span&gt;
                        &lt;span class=&quot;chip green&quot;&gt;Гипотезы&lt;/span&gt;
                        &lt;span class=&quot;chip green&quot;&gt;Метрики&lt;/span&gt;
                      &lt;/div&gt;
                      &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                        &lt;button class=&quot;button ghost&quot; data-diag-next=&quot;task&quot;&gt;Назад&lt;/button&gt;
                        &lt;button class=&quot;button primary&quot; id=&quot;toSimulator&quot;&gt;Перейти в симулятор&lt;/button&gt;
                      &lt;/div&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div class=&quot;upload-zone&quot;&gt;
                  &lt;div class=&quot;row&quot;&gt;
                    &lt;div class=&quot;upload&quot; id=&quot;excelZone&quot;&gt;
                      &lt;div class=&quot;section-title&quot;&gt;
                        &lt;h3&gt;Excel с критериями&lt;/h3&gt;
                        &lt;span class=&quot;status wait&quot; id=&quot;excelStatus&quot;&gt;Ожидает&lt;/span&gt;
                      &lt;/div&gt;
                      &lt;p id=&quot;excelText&quot;&gt;Файл не выбран&lt;/p&gt;
                      &lt;button class=&quot;button secondary&quot; id=&quot;excelBtn&quot;&gt;Загрузить файл&lt;/button&gt;
                      &lt;input class=&quot;hidden-input&quot; id=&quot;excelInput&quot; type=&quot;file&quot; accept=&quot;.xlsx,.xls&quot; /&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;upload&quot; id=&quot;wordZone&quot;&gt;
                      &lt;div class=&quot;section-title&quot;&gt;
                        &lt;h3&gt;Word с кейсом и заданиями&lt;/h3&gt;
                        &lt;span class=&quot;status wait&quot; id=&quot;wordStatus&quot;&gt;Ожидает&lt;/span&gt;
                      &lt;/div&gt;
                      &lt;p id=&quot;wordText&quot;&gt;Файл не выбран&lt;/p&gt;
                      &lt;button class=&quot;button secondary&quot; id=&quot;wordBtn&quot;&gt;Загрузить файл&lt;/button&gt;
                      &lt;input class=&quot;hidden-input&quot; id=&quot;wordInput&quot; type=&quot;file&quot; accept=&quot;.docx,.doc&quot; /&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/div&gt;
              &lt;/div&gt;
            &lt;/section&gt;

            &lt;section class=&quot;screen&quot; id=&quot;screen-simulator&quot;&gt;
              &lt;div class=&quot;section-header&quot;&gt;
                &lt;h3&gt;Симулятор продуктовых навыков&lt;/h3&gt;
                &lt;div class=&quot;stepper&quot;&gt;
                  &lt;button class=&quot;step-btn active&quot; data-sim-step=&quot;skills&quot;&gt;Навыки&lt;/button&gt;
                  &lt;button class=&quot;step-btn&quot; data-sim-step=&quot;session&quot;&gt;Прохождение&lt;/button&gt;
                  &lt;button class=&quot;step-btn&quot; data-sim-step=&quot;results&quot;&gt;Итог&lt;/button&gt;
                &lt;/div&gt;
              &lt;/div&gt;

              &lt;div class=&quot;demo-stage&quot;&gt;
                &lt;div class=&quot;panel&quot; data-sim-view=&quot;skills&quot;&gt;
                  &lt;div class=&quot;section-title&quot;&gt;
                    &lt;h3&gt;Доступные навыки&lt;/h3&gt;
                    &lt;span class=&quot;chip purple&quot;&gt;Рекомендации из диагностики&lt;/span&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;skill-grid section-gap-top&quot;&gt;
                    &lt;div class=&quot;skill&quot;&gt;
                      &lt;h3&gt;Анализ рынка&lt;/h3&gt;
                      &lt;p&gt;Статус: не начат&lt;/p&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip green&quot;&gt;Рекомендован&lt;/span&gt;&lt;/div&gt;
                      &lt;button class=&quot;button secondary&quot;&gt;Открыть&lt;/button&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;skill result-highlight&quot;&gt;
                      &lt;h3&gt;Метрики продукта&lt;/h3&gt;
                      &lt;p&gt;Статус: в процессе&lt;/p&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip green&quot;&gt;Рекомендован&lt;/span&gt;&lt;/div&gt;
                      &lt;button class=&quot;button secondary&quot;&gt;Открыть&lt;/button&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;skill result-highlight&quot;&gt;
                      &lt;h3&gt;Гипотезы&lt;/h3&gt;
                      &lt;p&gt;Статус: не начат&lt;/p&gt;
                      &lt;div class=&quot;chips&quot;&gt;&lt;span class=&quot;chip green&quot;&gt;Рекомендован&lt;/span&gt;&lt;/div&gt;
                      &lt;button class=&quot;button primary&quot; data-sim-next=&quot;session&quot;&gt;Начать навык&lt;/button&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div class=&quot;panel&quot; data-sim-view=&quot;session&quot; hidden&gt;
                  &lt;div class=&quot;section-title&quot;&gt;
                    &lt;h3&gt;Прохождение навыка: Гипотезы&lt;/h3&gt;
                    &lt;span class=&quot;chip&quot;&gt;Шаг 3 из 8&lt;/span&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;progress section-gap-top&quot;&gt;&lt;span class=&quot;progress-38&quot;&gt;&lt;/span&gt;&lt;/div&gt;
                  &lt;div class=&quot;stack section-gap-top&quot;&gt;
                    &lt;div class=&quot;block subtle&quot;&gt;
                      &lt;h3&gt;Теория&lt;/h3&gt;
                      &lt;p&gt;Сильная продуктовая гипотеза описывает изменение, целевой сегмент, ожидаемое изменение поведения и измеримый эффект на метрику.&lt;/p&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;block subtle&quot;&gt;
                      &lt;h3&gt;Кейс&lt;/h3&gt;
                      &lt;p&gt;Команда видит падение активации в онбординге. Нужно определить первую гипотезу для теста и способ оценки результата.&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;block section-gap-top&quot;&gt;
                    &lt;h3&gt;Какой вариант вы выберете?&lt;/h3&gt;
                    &lt;div class=&quot;option-list&quot;&gt;
                      &lt;div class=&quot;option active&quot;&gt;
                        &lt;span&gt;Сократить число шагов онбординга&lt;/span&gt;
                        &lt;span class=&quot;chip purple&quot;&gt;Выбрано&lt;/span&gt;
                      &lt;/div&gt;
                      &lt;div class=&quot;option&quot;&gt;&lt;span&gt;Добавить больше подсказок на каждом экране&lt;/span&gt;&lt;/div&gt;
                      &lt;div class=&quot;option&quot;&gt;&lt;span&gt;Расширить форму сбора профиля&lt;/span&gt;&lt;/div&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;block section-gap-top&quot; style=&quot;background:#f6fff8;border-color:#ccefd9;&quot;&gt;
                    &lt;h3&gt;Обратная связь&lt;/h3&gt;
                    &lt;p&gt;Вы выбрали наиболее проверяемую гипотезу: она устраняет ключевое трение в сценарии и позволяет быстро измерить эффект на activation.&lt;/p&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                    &lt;button class=&quot;button ghost&quot; data-sim-next=&quot;skills&quot;&gt;Назад&lt;/button&gt;
                    &lt;button class=&quot;button primary&quot; data-sim-next=&quot;results&quot;&gt;Завершить навык&lt;/button&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div data-sim-view=&quot;results&quot; hidden&gt;
                  &lt;div class=&quot;row&quot;&gt;
                    &lt;div class=&quot;result result-highlight stack-tight&quot;&gt;
                      &lt;h3&gt;Итог по навыку&lt;/h3&gt;
                      &lt;div class=&quot;score&quot;&gt;78%&lt;/div&gt;
                      &lt;p&gt;по закрытым вопросам&lt;/p&gt;
                    &lt;/div&gt;
                    &lt;div class=&quot;result stack-tight&quot;&gt;
                      &lt;h3&gt;Статус открытых ответов&lt;/h3&gt;
                      &lt;p&gt;Содержательно, но можно усилить аргументацию выбора и критерии успеха.&lt;/p&gt;
                    &lt;/div&gt;
                  &lt;/div&gt;
                  &lt;div class=&quot;footer-actions section-gap-top&quot;&gt;
                    &lt;button class=&quot;button ghost&quot; data-sim-next=&quot;session&quot;&gt;Назад&lt;/button&gt;
                    &lt;button class=&quot;button primary&quot; data-sim-next=&quot;skills&quot;&gt;К навыкам&lt;/button&gt;
                  &lt;/div&gt;
                &lt;/div&gt;

                &lt;div class=&quot;upload-zone&quot;&gt;
                  &lt;div class=&quot;upload&quot; id=&quot;simZone&quot;&gt;
                    &lt;div class=&quot;section-title&quot;&gt;
                      &lt;h3&gt;Word с контентом симулятора&lt;/h3&gt;
                      &lt;span class=&quot;status wait&quot; id=&quot;simStatus&quot;&gt;Ожидает&lt;/span&gt;
                    &lt;/div&gt;
                    &lt;p id=&quot;simText&quot;&gt;Файл не выбран&lt;/p&gt;
                    &lt;button class=&quot;button secondary&quot; id=&quot;simBtn&quot;&gt;Загрузить файл&lt;/button&gt;
                    &lt;input class=&quot;hidden-input&quot; id=&quot;simInput&quot; type=&quot;file&quot; accept=&quot;.docx,.doc&quot; /&gt;
                  &lt;/div&gt;
                &lt;/div&gt;
              &lt;/div&gt;
            &lt;/section&gt;
          &lt;/div&gt;
        &lt;/div&gt;
      &lt;/main&gt;
    &lt;/section&gt;
  &lt;/div&gt;

  &lt;script&gt;
    const ui = {
      topTabs: [...document.querySelectorAll(&#x27;.tab&#x27;)],
      topScreens: [...document.querySelectorAll(&#x27;.screen&#x27;)],
      title: document.getElementById(&#x27;screenTitle&#x27;),
      subtitle: document.getElementById(&#x27;screenSubtitle&#x27;),
      badge: document.getElementById(&#x27;screenBadge&#x27;),
      processingBar: document.getElementById(&#x27;processingBar&#x27;)
    };

    const screenMeta = {
      diagnostic: {
        title: &#x27;Диагностика продуктовых навыков&#x27;,
        subtitle: &#x27;Загрузите материалы и пройдите оценку навыков&#x27;,
        badge: &#x27;Раздел 1&#x27;
      },
      simulator: {
        title: &#x27;Симулятор продуктовых навыков&#x27;,
        subtitle: &#x27;Развивайте навыки через теорию, кейсы и практику&#x27;,
        badge: &#x27;Раздел 2&#x27;
      }
    };

    function showTopScreen(id) {
      const meta = screenMeta[id];
      if (!meta) return;
      ui.topTabs.forEach(tab =&gt; tab.classList.toggle(&#x27;active&#x27;, tab.dataset.screen === id));
      ui.topScreens.forEach(screen =&gt; screen.classList.toggle(&#x27;active&#x27;, screen.id === `screen-${id}`));
      ui.title.textContent = meta.title;
      ui.subtitle.textContent = meta.subtitle;
      ui.badge.textContent = meta.badge;
    }

    function bindStepGroup(stepSelector, viewSelector, stepKey, viewKey) {
      const stepButtons = [...document.querySelectorAll(stepSelector)];
      const views = [...document.querySelectorAll(viewSelector)];

      const activate = id =&gt; {
        stepButtons.forEach(button =&gt; button.classList.toggle(&#x27;active&#x27;, button.dataset[stepKey] === id));
        views.forEach(view =&gt; {
          view.hidden = view.dataset[viewKey] !== id;
        });
      };

      stepButtons.forEach(button =&gt; {
        button.addEventListener(&#x27;click&#x27;, () =&gt; activate(button.dataset[stepKey]));
      });

      return activate;
    }

    const showDiagStep = bindStepGroup(&#x27;[data-diag-step]&#x27;, &#x27;[data-diag-view]&#x27;, &#x27;diagStep&#x27;, &#x27;diagView&#x27;);
    const showSimStep = bindStepGroup(&#x27;[data-sim-step]&#x27;, &#x27;[data-sim-view]&#x27;, &#x27;simStep&#x27;, &#x27;simView&#x27;);

    document.querySelectorAll(&#x27;[data-diag-next]&#x27;).forEach(button =&gt; {
      button.addEventListener(&#x27;click&#x27;, () =&gt; showDiagStep(button.dataset.diagNext));
    });

    document.querySelectorAll(&#x27;[data-sim-next]&#x27;).forEach(button =&gt; {
      button.addEventListener(&#x27;click&#x27;, () =&gt; showSimStep(button.dataset.simNext));
    });

    ui.topTabs.forEach(tab =&gt; {
      tab.addEventListener(&#x27;click&#x27;, () =&gt; showTopScreen(tab.dataset.screen));
    });

    document.getElementById(&#x27;toSimulator&#x27;)?.addEventListener(&#x27;click&#x27;, () =&gt; {
      showTopScreen(&#x27;simulator&#x27;);
    });

    function wireUpload(config) {
      const button = document.getElementById(config.buttonId);
      const input = document.getElementById(config.inputId);
      const zone = document.getElementById(config.zoneId);
      const text = document.getElementById(config.textId);
      const status = document.getElementById(config.statusId);

      if (!button || !input || !zone || !text || !status) return;

      button.addEventListener(&#x27;click&#x27;, () =&gt; input.click());
      input.addEventListener(&#x27;change&#x27;, () =&gt; {
        const file = input.files?.[0];
        if (!file) return;
        zone.classList.add(&#x27;good&#x27;);
        text.textContent = file.name;
        status.textContent = config.successText;
        status.className = &#x27;status ok&#x27;;
      });
    }

    [
      { buttonId:&#x27;excelBtn&#x27;, inputId:&#x27;excelInput&#x27;, zoneId:&#x27;excelZone&#x27;, textId:&#x27;excelText&#x27;, statusId:&#x27;excelStatus&#x27;, successText:&#x27;Загружен&#x27; },
      { buttonId:&#x27;wordBtn&#x27;, inputId:&#x27;wordInput&#x27;, zoneId:&#x27;wordZone&#x27;, textId:&#x27;wordText&#x27;, statusId:&#x27;wordStatus&#x27;, successText:&#x27;Загружен&#x27; },
      { buttonId:&#x27;simBtn&#x27;, inputId:&#x27;simInput&#x27;, zoneId:&#x27;simZone&#x27;, textId:&#x27;simText&#x27;, statusId:&#x27;simStatus&#x27;, successText:&#x27;Загружен&#x27; }
    ].forEach(wireUpload);

    document.getElementById(&#x27;finishProcessing&#x27;)?.addEventListener(&#x27;click&#x27;, () =&gt; {
      ui.processingBar.style.width = &#x27;100%&#x27;;
      window.setTimeout(() =&gt; showDiagStep(&#x27;results&#x27;), 300);
    });

    showTopScreen(&#x27;diagnostic&#x27;);
    showDiagStep(&#x27;intro&#x27;);
    showSimStep(&#x27;skills&#x27;);
  &lt;/script&gt;
&lt;/body&gt;
&lt;/html&gt;</pre>
</body>
</html>